# ─── DATABASE ─────────────────────────────────────────────────────────────────
# Local dev  : DATABASE_URL="file:./dev.db"  (SQLite — changer provider en "sqlite" dans schema.prisma)
# Production : DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
#              → Récupérer depuis Vercel Postgres, Supabase ou Neon
DATABASE_URL=""

# ─── NEXTAUTH ─────────────────────────────────────────────────────────────────
# Générer un secret fort : openssl rand -base64 32
AUTH_SECRET=""

# URL publique de l'app (sans slash final)
# Local      : http://localhost:3000
# Production : https://fittrack-xxx.vercel.app
NEXTAUTH_URL=""
